# ============================================================================
# .env.example — template variabili d'ambiente del frontend Next.js
# ----------------------------------------------------------------------------
# COPIA questo file in `.env.local`:
#     cp .env.example .env.local
#
# IMPORTANTE: solo variabili che iniziano con `NEXT_PUBLIC_` vengono
# inlinate nel bundle JavaScript che arriva al browser. Tutte le altre
# sono visibili solo al server (Server Components / Route Handlers).
# Quindi: NON mettere mai chiavi segrete in NEXT_PUBLIC_*.
# ============================================================================

# URL del backend FastAPI usata dai Client Components per fare fetch.
# In dev: il backend gira su localhost:8000 (vedi apps/api).
# In prod (M5): sarà l'URL pubblica del backend.
NEXT_PUBLIC_API_URL=http://localhost:8000
