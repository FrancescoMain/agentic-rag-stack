# ========================================================================
# .env.example — TEMPLATE delle variabili d'ambiente
# ------------------------------------------------------------------------
# COPIA questo file in `.env` e riempilo con le tue chiavi reali:
#     cp .env.example .env
#
# Il file `.env` è in .gitignore: non sarà mai committato.
# Le variabili qui sotto sono raggruppate per la milestone in cui servono.
# Finché una milestone non è in corso, lascia pure i valori vuoti.
# ========================================================================

# ------------------------------------------------------------------------
# M1 — Backend foundations
# ------------------------------------------------------------------------
# Ambiente di esecuzione del backend. "development" attiva log verbose,
# reload automatico, ecc. In produzione metteremo "production".
APP_ENV=development

# Porta su cui FastAPI espone il server. 8000 è la default di uvicorn.
API_PORT=8000

# Origine del frontend, usata per configurare la CORS policy del backend.
# In dev è http://localhost:3000 (Next.js default).
FRONTEND_ORIGIN=http://localhost:3000

# Livello minimo dei log emessi: DEBUG | INFO | WARNING | ERROR | CRITICAL.
# Default INFO. Usa DEBUG in dev solo se devi indagare a fondo (mostra
# anche il chiacchiericcio interno di httpx, anthropic, ecc.).
LOG_LEVEL=INFO

# Formato dei log: "dev" (umano colorato) o "json" (strutturato per
# aggregatori esterni come Datadog/CloudWatch). Default "dev".
# Per provare il JSON in locale: LOG_FORMAT=json uv run uvicorn app.main:app
LOG_FORMAT=dev


# ------------------------------------------------------------------------
# M1/M2 — LLM provider keys
# ------------------------------------------------------------------------
# Anthropic Claude: usata per ragionamento agentico (LangGraph).
# Ottieni una chiave da https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI: usata per text-embedding-3-small (embeddings) e GPT-4o (task economici).
# Ottieni una chiave da https://platform.openai.com/
OPENAI_API_KEY=


# ------------------------------------------------------------------------
# M2 — Vector database
# ------------------------------------------------------------------------
# Pinecone (vector DB managed) — opzione default secondo l'ADR.
# Alternative: pgvector self-hosted via docker compose (vedi M5).
PINECONE_API_KEY=
PINECONE_INDEX_NAME=agentic-rag-demo
PINECONE_ENVIRONMENT=us-east-1

# Cohere — usato per il reranker (modello rerank-3).
# Alternativa: BGE reranker self-hosted (più lento ma gratis).
COHERE_API_KEY=


# ------------------------------------------------------------------------
# M5 — Observability
# ------------------------------------------------------------------------
# Langfuse — tracing di ogni chiamata LLM, tool call, retrieval.
# Si può usare cloud (langfuse.com) o self-hosted via docker compose.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
